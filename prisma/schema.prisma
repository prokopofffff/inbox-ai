// Inbox AI — Prisma schema
// Postgres (Supabase). Generated client consumed via lib/prisma.ts singleton.

generator client {
  provider = "prisma-client-js"
}

// Prisma 7 moved connection URLs out of the schema and into prisma.config.ts.
// See prisma.config.ts, where datasource.url reads env("DATABASE_URL") and the
// direct/shadow connection reads env("DIRECT_URL").
datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum EmailStatus {
  UNREAD
  READ
  ARCHIVED
}

enum Category {
  SUPPORT
  SALES
  BILLING
  SPAM
  GENERAL
  INTERNAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum RuleField {
  SUBJECT
  FROM
  BODY
}

enum RuleOperator {
  CONTAINS
  EQUALS
  STARTS_WITH
}

enum RuleActionType {
  ASSIGN
  SET_PRIORITY
  SET_CATEGORY
  SET_TEAM
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users           User[]
  mailboxes       Mailbox[]
  automationRules AutomationRule[]
  tasks           Task[]
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  role       Role     @default(MEMBER)
  supabaseId String   @unique
  orgId      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  assignedEmails Email[] @relation("EmailAssignee")
  assignedTasks  Task[]  @relation("TaskAssignee")

  @@index([orgId])
}

model Mailbox {
  id           String   @id @default(cuid())
  email        String
  provider     String   @default("gmail")
  accessToken  String?
  refreshToken String?
  historyId    String?
  orgId        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  emails Email[]

  @@index([orgId])
}

model Email {
  id         String      @id @default(cuid())
  gmailId    String      @unique
  threadId   String?
  fromAddr   String
  fromName   String?
  toAddr     String?
  subject    String?
  snippet    String?
  bodyText   String?
  bodyHtml   String?
  receivedAt DateTime
  status     EmailStatus @default(UNREAD)
  assigneeId String?
  mailboxId  String
  raw        Json?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  assignee       User?           @relation("EmailAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  mailbox        Mailbox         @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  classification Classification?
  tasks          Task[]

  @@index([mailboxId])
  @@index([status])
  @@index([receivedAt])
  @@index([assigneeId])
}

model Classification {
  id             String    @id @default(cuid())
  emailId        String    @unique
  category       Category
  priority       Priority
  summary        String
  suggestedReply String
  sentiment      Sentiment
  confidence     Float
  assignee       String?
  model          String?
  createdAt      DateTime  @default(now())

  email Email @relation(fields: [emailId], references: [id], onDelete: Cascade)
}

model AutomationRule {
  id             String         @id @default(cuid())
  name           String
  conditionField RuleField
  operator       RuleOperator
  value          String
  actionType     RuleActionType
  actionValue    String
  enabled        Boolean        @default(true)
  orgId          String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Task {
  id         String     @id @default(cuid())
  title      String
  status     TaskStatus @default(OPEN)
  dueAt      DateTime?
  emailId    String?
  assigneeId String?
  orgId      String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  email    Email? @relation(fields: [emailId], references: [id], onDelete: SetNull)
  assignee User?  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([emailId])
  @@index([assigneeId])
}
